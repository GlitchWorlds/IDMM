{
  "manifest_version": 3,
  "name": "IDMM  Download Manager Max",
  "short_name": "IDMM",
  "version": "1.2.4",
  "description": "Free, open-source download manager with multi-threaded acceleration. Intercepts downloads and sends them to IDMM for maximum speed.",

  "permissions": [
    "downloads",
    "activeTab",
    "storage",
    "contextMenus"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "IDMM Download Manager"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "minimum_chrome_version": "109",

  "browser_specific_settings": {
    "gecko": {
      "id": "idmm-extension@glitchworlds",
      "strict_min_version": "109.0"
    }
  },

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src http://127.0.0.1:9977 ws://127.0.0.1:9977; img-src 'self' data:"
  }
}

